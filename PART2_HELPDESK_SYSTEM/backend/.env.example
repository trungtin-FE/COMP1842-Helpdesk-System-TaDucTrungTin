# Server Configuration
# The port number the backend server will run on (e.g., 5000, 8080)
PORT=

# Database Configuration
# Your MongoDB connection string
# Local example: mongodb://localhost:27017/your_database_name
MONGO_URI=

# IMPORTANT NOTE:
# After configuring the MONGO_URI above, ensure that the collection name 
# in your Mongoose/MongoDB model matches your database setup.
# Check your: backend/api/models/Response.js 
